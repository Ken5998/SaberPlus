<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Cerchio badge -->
    <item
        android:gravity="top|end"
        android:width="22dp"
        android:height="22dp"
        android:right="20dp"
        android:top="18dp">
        <shape android:shape="oval">
            <solid android:color="#FF047857"/>
            <stroke android:width="1.5dp" android:color="#FFFFFFFF"/>
        </shape>
    </item>

    <!-- Linea orizzontale + -->
    <item
        android:gravity="top|end"
        android:width="10dp"
        android:height="2dp"
        android:right="27dp"
        android:top="28dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFFFF"/>
            <corners android:radius="1dp"/>
        </shape>
    </item>

    <!-- Linea verticale + -->
    <item
        android:gravity="top|end"
        android:width="2dp"
        android:height="10dp"
        android:right="31dp"
        android:top="24dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFFFF"/>
            <corners android:radius="1dp"/>
        </shape>
    </item>

</layer-list>
